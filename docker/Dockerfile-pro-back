FROM node:18-alpine

USER root

ENV HOME_DIR "/home/node/app"
WORKDIR $HOME_DIR
COPY back/ .

RUN chown -R node:node $HOME_DIR
RUN chmod -R 700 $HOME_DIR

USER node

RUN npm install

# compile at build time: container start stays fast during live patches,
# and a type error fails the build instead of the mid-stream restart
RUN npx tsc

CMD npm run migrate && node build/index.js